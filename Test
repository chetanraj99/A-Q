public class DocReader {

    public static String read(String path) throws Exception {

        XWPFDocument document =
                new XWPFDocument(
                        new FileInputStream(path));

        StringBuilder sb = new StringBuilder();

        document.getParagraphs()
                .forEach(p ->
                        sb.append(p.getText())
                          .append("\n"));

        return sb.toString();
    }
}




